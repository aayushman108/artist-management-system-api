<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Your Password - Artist Management System</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <div class="container">
      <div class="logo">Artist Management System</div>

      <h1>Reset your password</h1>

      <p>Hello <%= fullName %>,</p>
      <p>
        We received a request to reset the password for your
        <strong>Artist Management System</strong> account. Click the button
        below to set a new password.
      </p>

      <div class="button-container">
        <a href="<%= resetUrl %>" class="button">Reset Password</a>
      </div>

      <p style="font-size: 14px; color: #888888">
        This password reset link expires in
        <strong>10 minutes</strong>. Please use it before then.
      </p>

      <p style="font-size: 14px; color: #888888">
        If the button doesn't work, you can copy and paste this link into your
        browser:<br />
        <a href="<%= resetUrl %>" style="color: #888888; word-break: break-all"
          ><%= resetUrl %></a
        >
      </p>

      <p style="font-size: 14px; color: #888888">
        If you didn't request a password reset, you can safely ignore this
        email. Your password will not be changed.
      </p>

      <div class="divider"></div>

      <div class="footer">
        <p>Artist Management System</p>
        <p>&copy; 2026 All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
