  "main": "dist/src/index.js",
  "scripts": {
    "migrate:list": "npx knex migrate:list --knexfile src/database/knexfile.ts",
    "migrate:up": "npx knex migrate:up --knexfile src/database/knexfile.ts",
    "migrate:down": "npx knex migrate:down --knexfile src/database/knexfile.ts",
    "migrate:rollback": "npx knex migrate:rollback --knexfile src/database/knexfile.ts",
    "migrate:latest": "npx knex migrate:latest --knexfile src/database/knexfile.ts",
    "migrate:make": "npx knex migrate:make create_user_table -x ts --knexfile src/database/knexfile.ts",
    "dev": "nodemon --exec ts-node-dev -r tsconfig-paths/register --files src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/src/index.js"
  },
